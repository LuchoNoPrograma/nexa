DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexa
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
# Clave secreta del servidor. Nunca usar el prefijo NUXT_PUBLIC_ ni exponerla al navegador.
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=productos
NEXA_SUPER_ADMIN_EMAIL=admin@nexa.bo
NEXA_SUPER_ADMIN_PASSWORD=NexaAdmin2026!

# OAuth con Google (Authorization Code + PKCE).
# Crea credenciales OAuth (tipo "Aplicacion web") en Google Cloud Console y
# registra como "URI de redireccionamiento autorizado":
#   http://localhost:3000/api/auth/oauth/google/callback   (desarrollo)
#   https://TU_DOMINIO/api/auth/oauth/google/callback       (produccion)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opcional: fuerza el dominio del callback si un proxy oculta el host real
# (p. ej. en el VPS). Si se deja vacio, se deriva del propio request.
# NEXA_PUBLIC_URL=https://TU_DOMINIO
