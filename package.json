{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "db:migrate": "dbmate --migrations-dir database/local --no-dump-schema migrate",
    "db:rollback": "dbmate --migrations-dir database/local --no-dump-schema rollback",
    "db:status": "dbmate --migrations-dir database/local status",
    "dev": "npm run db:migrate && LAUNCH_EDITOR=idea nuxt dev",
    "host": "npm run db:migrate && LAUNCH_EDITOR=idea nuxt dev --host",
    "generate": "nuxt generate",
    "preview": "nuxt preview"
  },
  "dependencies": {
    "@nuxt/icon": "^2.2.3",
    "@pinia/nuxt": "^0.11.3",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/vite": "^4.3.0",
    "jspreadsheet-ce": "^5.0.4",
    "jsuites": "^6.4.0",
    "nuxt": "^4.4.7",
    "pg": "^8.21.0",
    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "sweetalert2": "^11.26.25",
    "tailwindcss": "^4.3.0",
    "tailwindcss-primeui": "^0.6.1",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@primevue/nuxt-module": "^4.5.5",
    "dbmate": "^2.33.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
